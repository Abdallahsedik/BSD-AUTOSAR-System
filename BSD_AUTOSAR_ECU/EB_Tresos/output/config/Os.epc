                <ECUC-NUMERICAL-PARAM-VALUE>
                  <DEFINITION-REF DEST="ECUC-INTEGER-PARAM-DEF">/dSPACE_Sim/Os/OsCounter/OsCounterMinCycle</DEFINITION-REF>
                  <VALUE>1</VALUE>
