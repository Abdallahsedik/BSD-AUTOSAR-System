                <ECUC-TEXTUAL-PARAM-VALUE>
                  <DEFINITION-REF DEST="ECUC-ENUMERATION-PARAM-DEF">/dSPACE_Sim/Os/OsOS/OsStatus</DEFINITION-REF>
                  <VALUE>EXTENDED</VALUE>
